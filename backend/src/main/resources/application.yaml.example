spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/petmatch_db
    username: postgres
    password: 123456

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.PostgreSQLDialect

  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 20MB

server:
  port: 8080

jwt:
  secret: abcdefghijklmnopqrstuvwxyz
  expiration: 86400000

cloudinary:
  cloud-name=your_cloud_name
  api-key=123456789012345
  api-secret=abcdefghijklmnopqrstuvwxyz